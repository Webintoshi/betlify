# Coolify deployment environment (frontend + backend + self-hosted Supabase)

# Runtime ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Backend to Supabase (self-hosted)
SUPABASE_URL=https://supabase.example.com/rest/v1
SUPABASE_SERVICE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# Frontend public Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY

# Frontend -> Backend routing
NEXT_PUBLIC_BACKEND_URL=/api/backend
BACKEND_INTERNAL_URL=http://backend:8000
SERVICE_URL_BACKEND=http://backend:8000
BACKEND_URL=http://backend:8000

# CORS allowlist for backend (comma-separated)
CORS_ALLOW_ORIGINS=https://app.example.com,https://www.app.example.com

# Optional provider keys
API_FOOTBALL_KEY=
THE_ODDS_API_KEY=
ODDS_API_IO_KEY=
ODDS_API_BOOKMAKER=Betfair Exchange
ODDS_API_MAX_REQ_PER_HOUR=100
ODDS_API_MIN_DEPTH=50
ODDS_API_MAX_SPREAD_PCT=0.06
OPENWEATHER_API_KEY=

DEFAULT_SEASON=2024
